{
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(cp *)",
      "Bash(awk *)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(docker compose ps)",
      "Bash(make lint)",
      "Bash(make type-check)",
      "Bash(make test)",
      "Bash(make build)",
      "Bash(make db:up)",
      "Bash(make db:down)",
      "Bash(make db:migrate)",
      "Bash(make db:generate)",
      "Bash(npx prisma *)",
      "Bash(docker compose *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git switch *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git worktree *)",
      "Bash(git fetch *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh project list *)",
      "Bash(gh repo view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh workflow list *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff"
          },
          {
            "type": "command",
            "command": "osascript -e 'display notification \"処理完了\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"許可待ち\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  }
}
